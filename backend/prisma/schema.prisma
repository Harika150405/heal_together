datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  fname        String
  lname        String
  password     String
  conpassword  String
  gender       String
  email        String    @unique
  phone        String
  address      String    @db.Text
  verified     Boolean   @default(false)
  otp          String?
  otpExpiry    DateTime?
  joinedGroups String?   @db.Text
  role         String    @default("USER")
}

model CommunityGroup {
  id           Int    @id @default(autoincrement())
  groupName    String @unique
  description  String @db.Text
  tagline      String @db.Text
  membersCount Int    @default(0)
}

model JoinedCommunity {
  id            Int      @id @default(autoincrement())
  username      String
  communityName String
  lastActive    DateTime @default(now()) @updatedAt

  @@unique([username, communityName])
}

model Message {
  id            Int      @id @default(autoincrement())
  communityName String
  username      String
  message       String   @db.Text
  timestamp     DateTime @default(now())
}

model Story {
  id        Int      @id @default(autoincrement())
  name      String // author username
  community String
  story     String   @db.Text
  createdAt DateTime @default(now())
}

model Like {
  id        Int      @id @default(autoincrement())
  storyId   Int
  username  String
  createdAt DateTime @default(now())

  @@unique([storyId, username])
}

model Comment {
  id        Int      @id @default(autoincrement())
  storyId   Int
  username  String
  comment   String   @db.Text
  createdAt DateTime @default(now())
}
